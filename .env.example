# ──────────────────────────────────────────────────────────────
# Agentic-Hub — configuration d'exemple
# Copier en `.env` et compléter. AUCUNE clé Claude/Anthropic requise.
# ──────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic
POSTGRES_DB=agentic_hub
# Port hôte exposant Postgres (client DB externe). L'API se connecte en interne,
# donc ce port n'a pas besoin d'être libre pour que l'app marche — changer si 5432 est pris.
POSTGRES_HOST_PORT=5432
# URL utilisée par l'API (Prisma). En docker-compose, host = "postgres".
DATABASE_URL=postgresql://agentic:agentic@localhost:5432/agentic_hub?schema=public

# API
API_PORT=3000
# Port hôte exposant l'API (docker-compose). Changer si 3000 est déjà pris.
# Si modifié, aligner VITE_API_BASE ci-dessous (rebuild du web nécessaire).
API_HOST_PORT=3000
# Port hôte exposant l'interface web (docker-compose). Changer si 8080 est déjà pris.
WEB_PORT=8080
# Origine autorisée pour le frontend (CORS). En docker-compose, mettre http://localhost:${WEB_PORT}.
WEB_ORIGIN=http://localhost:5173

# Token partagé que la CI (GitHub Actions) utilise pour POSTer les findings sur /api/ingest
INGEST_TOKEN=change-me-ingest-token

# ── Connexion GitHub ──────────────────────────────────────────
# Deux options (au choix) :
#
# OPTION A (recommandée) — Connexion via compte GitHub (OAuth) :
#   1. https://github.com/settings/developers → "New OAuth App"
#   2. Homepage URL        : http://localhost:8088   (ton interface web)
#      Authorization callback URL : http://localhost:3200/api/auth/github/callback
#      (le port doit matcher API_HOST_PORT)
#   3. Récupère le Client ID, puis "Generate a new client secret"
#   4. Renseigne ci-dessous, lance l'app, et clique "Se connecter" dans l'UI.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Optionnel : surcharger l'URL de callback (sinon déduite de API_HOST_PORT)
GITHUB_OAUTH_CALLBACK_URL=
# Scopes demandés (repo = repos privés, read:org = organisations)
GITHUB_OAUTH_SCOPE=repo read:org
#
# OPTION C (avancée) — GitHub App (quotas élevés, permissions fines) :
#   Créer une GitHub App, l'installer sur le compte/org, puis renseigner :
GITHUB_APP_ID=
# Clé privée PEM (coller le contenu, ou sa version base64)
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
#
# OPTION B (sans OAuth) — Personal Access Token :
#   https://github.com/settings/tokens → "Generate new token"
#   - Token classique : cocher "repo" (+ "workflow" si mode hybride)
#   - ou Fine-grained : accès "Contents: Read-only" sur les repos voulus
GITHUB_TOKEN=
# Propriétaire par défaut à synchroniser avec un PAT (user ou org). Laisser vide
# si tu utilises OAuth (tous tes repos + orgs sont récupérés automatiquement).
GITHUB_OWNER=
# Type de propriétaire: "user" ou "org"
GITHUB_OWNER_TYPE=user
# Repo hébergeant le workflow d'audit (au format owner/repo) déclenché via workflow_dispatch
AUDIT_WORKFLOW_REPO=
AUDIT_WORKFLOW_FILE=audit.yml

# Ollama (narration LLM locale, gratuite). Laisser tel quel pour docker-compose.
OLLAMA_URL=http://localhost:11434
# Port hôte exposant Ollama (utilisé par l'installeur pour la barre de progression).
# Changer si 11434 est déjà pris (ex: Ollama installé nativement).
OLLAMA_HOST_PORT=11434
OLLAMA_MODEL=qwen2.5-coder:7b
# Mettre à "false" pour désactiver complètement la narration LLM (rapports en gabarit statique)
OLLAMA_ENABLED=true

# Frontend (Vite) — base de l'API
VITE_API_BASE=http://localhost:3000
