# Normalisation des fins de ligne.
* text=auto

# Scripts shell : DOIVENT rester en LF (sinon "bad interpreter" sur macOS/Linux).
*.sh        text eol=lf
*.command   text eol=lf

# Scripts Windows : CRLF.
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binaires éventuels
*.png binary
*.jpg binary
*.ico binary
